{
  "name": "support-ticket-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Support ticket management system with an enforced status state machine",
  "scripts": {
    "setup": "npm install && npm --prefix web install && npm run db:setup",
    "db:setup": "node src/db-setup.js",
    "dev:api": "node src/server.js",
    "dev:web": "npm --prefix web run dev",
    "start": "node src/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^2.1.5"
  }
}
